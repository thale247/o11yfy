{
  "title": "Error Tracking",
  "panels": [
    {
      "type": "timeseries",
      "title": "Error Rate (%)",
            "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]) / rate(http_server_requests_seconds_count[1m]) * 100"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Total Errors",
            "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])"
        }
      ]
    },
    {
      "type": "table",
      "title": "Errors by Endpoint",
            "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) by (uri)"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1
}